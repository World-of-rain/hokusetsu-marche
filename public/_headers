# Cloudflare Pages のセキュリティヘッダ設定
# Google AdSense を動作させるため、Google広告エコシステムのドメインを許可している。
# 広告クリエイティブは無数の広告主ドメインから配信されるため img-src は https: を許容する。
/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=()
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://*.googlesyndication.com https://*.googleadservices.com https://*.google.com https://*.doubleclick.net https://*.googletagservices.com https://*.gstatic.com https://*.adtrafficquality.google; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; connect-src 'self' https://*.googlesyndication.com https://*.google.com https://*.doubleclick.net https://*.googleadservices.com https://*.gstatic.com https://*.adtrafficquality.google; frame-src 'self' https://*.googlesyndication.com https://*.doubleclick.net https://*.google.com https://*.adtrafficquality.google; font-src 'self' data:; frame-ancestors 'none'; base-uri 'self'; form-action 'self'

# Service Workerは常に最新を取得させる
/sw.js
  Cache-Control: no-cache

# アイコン・OG画像は長期キャッシュ
/icons/*
  Cache-Control: public, max-age=604800
/og-image.png
  Cache-Control: public, max-age=604800
